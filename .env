# ──────────────────────────────────────────────────────────────
# Configurações do Qdrant
# ──────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost
QDRANT_PORT=6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=sintomas_embeddings
EMBEDDING_DIMENSION=1024

# ──────────────────────────────────────────────────────────────
# Configurações do PostgreSQL
# ──────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=admin123
POSTGRES_POOL_SIZE=10

# ──────────────────────────────────────────────────────────────
# Configurações do E5 Embedding
# ──────────────────────────────────────────────────────────────
E5_MODEL_NAME=intfloat/multilingual-e5-large-instruct
E5_CACHE_DIR=./models

# ──────────────────────────────────────────────────────────────
# Configurações do spaCy NER
# ──────────────────────────────────────────────────────────────
SPACY_MODEL_NAME=pt_core_news_md
# SPACY_CUSTOM_MODEL_PATH=/path/to/custom/model

# ──────────────────────────────────────────────────────────────
# Configurações de Normalização
# ──────────────────────────────────────────────────────────────
SIMILARITY_THRESHOLD=0.65
TOP_K_SEARCH=1

# ──────────────────────────────────────────────────────────────
# Configurações do Ollama
# ──────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL_NAME=qwen3

# ──────────────────────────────────────────────────────────────
# Configurações da Aplicação
# ──────────────────────────────────────────────────────────────
DEBUG=false
LOG_LEVEL=INFO
