# Exemplo de arquivo .env - Copie para .env e configure com seus valores

# ============================================================================
# CONFIGURAÇÃO DE BANCO DE DADOS
# ============================================================================
# PostgreSQL Connection Details
DB_USER=postgres
DB_PASSWORD=sua_senha_postgres_aqui
DB_HOST=localhost
DB_PORT=5432
DB_NAME=fala_doutor

# ============================================================================
# CONFIGURAÇÃO DE DEBUG
# ============================================================================
# Exibir statements SQL no console (true/false)
SQL_ECHO=false

# ============================================================================
# CONFIGURAÇÃO DO OLLAMA
# ============================================================================
# URL base do servidor Ollama
OLLAMA_BASE_URL=http://localhost:11434
# Nome do modelo a usar
MODEL_NAME=qwen3

# ============================================================================
# NOTAS IMPORTANTES
# ============================================================================
# 1. Copie este arquivo para .env e prereencha com seus valores reais
# 2. Nunca commite .env com credenciais reais no git
# 3. Para produção, use variáveis de ambiente do sistema operacional
# 4. Mantenha senhas fortes e seguras
# 5. Faça backup regular do banco de dados
